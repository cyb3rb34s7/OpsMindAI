# Copy to apps/api/.env and fill in. Only recognized keys are allowed
# (Settings uses extra="forbid" — unknown keys will fail startup).

# LLM provider: groq (fast, hosted) | ollama (local, no rate limits) | openrouter | openai | claude | bedrock | deepseek
llm_provider=groq
groq_api_key=
# groq_model=llama-3.3-70b-versatile

# Local, rate-limit-free testing via Ollama (e.g. `ollama run gemma2`):
#   llm_provider=ollama
#   ollama_model=gemma4:e4b-it-q8_0       # any local model; qwen2.5:7b-instruct is faster
#   ollama_base_url=http://localhost:11434
# (Structured calls use Ollama JSON mode automatically; local inference is slower.)

# GitHub (real context-repo creation)
# Fine-grained PAT with Contents: write on the host repo below.
github_token=
github_context_repo=owner/your-context-repo

# Optional overrides
# database_path=./opsmindai.db
# max_cognitive_iterations=4
